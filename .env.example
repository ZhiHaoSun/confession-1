VITE_OPENAI_API_KEY=your_openai_api_key

# Google Cloud Storage Configuration
# Required for uploading memory photos to the cloud
GCS_BUCKET=your-bucket-name
GCS_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour...Private...Key...\n-----END PRIVATE KEY-----\n"

# Optional: Custom domain or CDN base URL for the bucket (e.g., https://cdn.yourdomain.com)
# GCS_PUBLIC_BASE_URL=

# Optional: where generated maze configs are stored
GCS_CONFIG_PREFIX=memorymaze/configs
