VITE_OPENAI_API_KEY=your_openai_api_key

# Server-only key for generated scene artwork and voice narration. ChatGPT Plus does not supply API credits.
OPENAI_API_KEY=your_openai_api_key
# Optional GPT Image configuration for Romantic Manga Diary scene backgrounds.
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_SIZE=2048x1152
OPENAI_IMAGE_JIGSAW_SIZE=2048x2048
OPENAI_IMAGE_OUTPUT_FORMAT=webp
OPENAI_IMAGE_OUTPUT_COMPRESSION=92
# Optional TTS configuration. If no custom voice ID is configured, narration uses cedar
# with gentle male-style delivery instructions for the final confession letter.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=cedar
# Optional: an already-created OpenAI custom voice ID for eligible API organizations.
# OPENAI_CUSTOM_VOICE_ID=voice_1234
# Optional: an already-created consent recording ID. If set, the uploaded
# creator sample is used to create a new custom voice during generation.
# OPENAI_VOICE_CONSENT_ID=cons_1234

# Google Cloud Storage Configuration
# Required for uploading memory photos to the cloud
GCS_BUCKET=your-bucket-name
GCS_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
GCS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour...Private...Key...\n-----END PRIVATE KEY-----\n"

# Optional: Custom domain or CDN base URL for the bucket (e.g., https://cdn.yourdomain.com)
# GCS_PUBLIC_BASE_URL=

# Optional: where generated maze configs are stored
GCS_CONFIG_PREFIX=memorymaze/configs
